{
	"name": "grapegram-web-client",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "biome lint --write --no-errors-on-unmatched",
		"format": "biome format --write --no-errors-on-unmatched",
		"format-imports": "prettier --write --ignore-unknown",
		"lint-check": "biome lint --no-errors-on-unmatched",
		"format-check": "biome format --no-errors-on-unmatched",
		"test": "vitest run",
		"preview": "vite preview",
		"prepare": "husky"
	},
	"dependencies": {
		"@radix-ui/react-icons": "^1.3.0",
		"@reduxjs/toolkit": "^2.2.6",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"normalize.css": "^8.0.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-redux": "^9.1.2",
		"react-router-dom": "^6.25.1",
		"redux": "^5.0.1",
		"tailwind-merge": "^2.4.0",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@biomejs/biome": "1.8.3",
		"@trivago/prettier-plugin-sort-imports": "^4.3.0",
		"@types/node": "^20.14.12",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@types/react-router-dom": "^5.3.3",
		"@vitejs/plugin-react": "^4.3.1",
		"autoprefixer": "^10.4.19",
		"husky": "^9.1.1",
		"lint-staged": "^15.2.7",
		"postcss": "^8.4.40",
		"prettier": "^3.3.3",
		"tailwindcss": "^3.4.7",
		"typescript": "^5.2.2",
		"vite": "^5.3.4",
		"vitest": "^2.0.4"
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
	"lint-staged": {
		"*": ["npm run lint", "npm run format-imports", "npm run format"],
		"!node_modules/**/*": [],
		"!dist/**/*": [],
		"!yarn.lock": [],
		"!.husky/**/*": [],
		"!.prettierrc": []
	}
}
